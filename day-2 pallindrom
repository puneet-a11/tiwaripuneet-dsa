#include<bitsstd/cpp.h>
using namespace std;

int main(){
    int num, reverse = 0, rem, original;

    cout<<"Enter a number: ";
    cin>>num;

    original = num;

    while(num != 0){
        rem = num % 10;
        reverse = reverse * 10 + rem;
        num = num / 10;
    }

    if(original == reverse){
        cout<<"Number is Palindrome";
    }
    else{
        cout<<"Number is not Palindrome";
    }

    return 0;
}
