#include <iostream>
using namespace std;

int main() {
    int n, sum = 0, r, temp;

    cout << "Enter number: ";
    cin >> n;

    temp = n;

    while(n > 0) {
        r = n % 10;
        sum = sum + r*r*r;
        n = n / 10;
    }

    if(sum == temp)
        cout << "Armstrong Number";
    else
        cout << "Not Armstrong Number";

    return 0;
}
